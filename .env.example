# sift environment template
#
# Copy to `.env` for local shell tooling if needed. Do not commit `.env` or
# real values. The Nix dev shell already exports a generated
# SIFT_METADATA__SECRET_KEY_FILE under `.sift/`.

# --- Server config: Figment maps SIFT_FOO__BAR to config.foo.bar ---

# HTTP bind address.
SIFT_BIND=127.0.0.1:7474

# Tracing filter used by sift config. `RUST_LOG` can also override tracing.
SIFT_LOG__FILTER=sift=info,tower_http=info

# Register mock drivers for local smoke tests and demos.
SIFT_DRIVERS__MOCK=false
SIFT_DRIVERS__MOCK_EXTRA=false

# Request and shutdown deadlines.
SIFT_TIMEOUTS__REQUEST_SECS=30
SIFT_TIMEOUTS__SHUTDOWN_DRAIN_SECS=30

# Auth. Leave bearer token unset for local loopback mode.
# Unsafe to commit with a real value.
# SIFT_AUTH__BEARER_TOKEN=
SIFT_AUTH__LOOPBACK_BYPASS=true

# Metadata store.
SIFT_METADATA__ENABLED=true
# Optional. If unset, sift uses the platform-local state path.
# SIFT_METADATA__PATH=.sift/metadata.sqlite3
SIFT_METADATA__SECRET_BACKEND=memory
# Required only when SIFT_METADATA__SECRET_BACKEND=file.
# Unsafe to commit if the referenced file or path is private.
# SIFT_METADATA__SECRET_KEY_FILE=.sift/dev-secret.key
SIFT_METADATA__BOOTSTRAP_LOCAL=true
SIFT_METADATA__STORE_SQL=true

# Audit/replay JSONL log path. May include query fingerprints and operational
# metadata; keep local unless intentionally shared.
# SIFT_AUDIT__OPERATION_LOG_PATH=.sift/operations.jsonl

# Synchronous HTTP execute caps.
SIFT_LIMITS__MAX_HTTP_RESULT_ROWS=10000
SIFT_LIMITS__MAX_HTTP_RESULT_BYTES=16777216

# --- Dev-shell / flake helper variables ---

# Override checkout path for flake commands.
# SIFT_REPO=/path/to/sift

# Backend lab helper defaults.
SIFT_BACKEND_LAB_MOCK=1
SIFT_BACKEND_LAB_READY_TRIES=480
SIFT_BACKEND_LAB_BACKEND_LOG=/tmp/sift-backend-lab-backend.log

# Smoke helper defaults.
SIFT_SMOKE_READY_TRIES=480
SIFT_SMOKE_LOG=/tmp/sift-smoke-server.log

# Demo Postgres helper defaults.
SIFT_DEMO_PGDATA=/tmp/sift-demo-pg
SIFT_DEMO_PG_LOG=/tmp/sift-demo-pg.log
SIFT_DEMO_PG_PORT=5433
SIFT_DEMO_PG_SOCKET_DIR=/tmp/sift-demo-pg-socket

# --- Live Postgres tests and benchmark ---

SIFT_PG_HOST=/tmp/sift-pg-socket
SIFT_PG_PORT=5433
SIFT_PG_DB=sifttest
SIFT_PG_USER=sift
# Unsafe to commit with a real value.
# SIFT_PG_PASSWORD=

# --- Live SQL Server tests and benchmark ---

SIFT_MSSQL_HOST=127.0.0.1
SIFT_MSSQL_PORT=1433
SIFT_MSSQL_DB=master
SIFT_MSSQL_USER=sa
# Required for live SQL Server tests/benchmarks.
# Unsafe to commit with a real value.
# SIFT_MSSQL_PASSWORD=

# --- Generic tool env used by the dev shell ---

RUST_BACKTRACE=1
RUST_LOG=sift=debug,info
SCCACHE_DIR=.cache/sccache
